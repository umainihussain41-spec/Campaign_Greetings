# ─────────────────────────────────────────────────────────────
# Public base URL of THIS app (what Exotel will fetch audio from
# and POST call-status to). On Railway this is your service URL.
# No trailing slash.
#   e.g. https://dynamic-greetings-production.up.railway.app
PUBLIC_BASE_URL=http://localhost:3000

PORT=3000

# Where MP3s AND the JSON data file live on disk. On Railway, attach a
# Volume and mount it here so uploads + data survive redeploys.
#   MP3s → $DATA_DIR/audio/*.mp3   data → $DATA_DIR/db.json
DATA_DIR=./data

# ─────────────────────────────────────────────────────────────
# Exotel API credentials (API Settings page on your Exotel dashboard)
EXOTEL_SID=your_account_sid
EXOTEL_API_KEY=your_api_key
EXOTEL_API_TOKEN=your_api_token
# Regional subdomain: api.exotel.com (default) or api.in.exotel.com
EXOTEL_SUBDOMAIN=api.exotel.com

# The ExoPhone / Virtual Number used as caller_id (default; can be
# overridden per campaign in the UI).
EXOTEL_CALLER_ID=

# Country code prepended to recipient numbers when normalizing to E.164
# for Exotel's Contacts API. Default 91 (India). Digits only, no '+'.
EXOTEL_COUNTRY_CODE=91

# The Flow (App Bazaar callflow) id whose Greeting/Connect applet is
# pointed at THIS app's /exotel/audio endpoint. All campaigns use it;
# the audio it plays is chosen dynamically by our webhook.
EXOTEL_APP_ID=

# Optional shared secret. If set, Exotel callback URLs must include
# ?token=THIS and our webhooks reject anything else.
WEBHOOK_TOKEN=
